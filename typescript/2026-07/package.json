{
  "name": "ai-native-skeleton",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --format=esm --target=node24 --packages=external --outfile=dist/main.js",
    "start": "node dist/main.js",
    "dev": "vite-node --watch src/main.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:deps": "depcruise --config .dependency-cruiser.cjs src",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run lint && npm run lint:deps && npm run test"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@types/node": "^24.0.0",
    "@typescript-eslint/rule-tester": "^8.63.0",
    "@typescript-eslint/utils": "^8.63.0",
    "dependency-cruiser": "^18.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "jiti": "^2.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "vite-node": "^6.0.0",
    "vitest": "^4.1.9"
  }
}
